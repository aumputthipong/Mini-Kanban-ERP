# ─────────────────────────────────────────────────────────────────────────────
# Backend env vars — copy to .env and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=8080
ENV=development                                  # "production" enables Secure cookies + stricter logs

# Database (must match docker-compose.yml or your remote Postgres)
DB_URL=postgres://erp_user:erp_password@localhost:5432/erp_kanban?sslmode=disable

# Migrations (relative to working dir; container uses /app/database/migrations)
MIGRATIONS_PATH=database/migrations
SKIP_MIGRATIONS=false                            # set true if running migrations out-of-band

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=replace-me-with-32+-bytes-of-random

# Frontend (used for CORS allow-origin and OAuth post-auth redirect)
FRONTEND_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
