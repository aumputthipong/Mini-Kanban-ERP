# ─────────────────────────────────────────────────────────────────────────────
# Backend env vars — copy to .env and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=8080
ENV=development                                  # "production" enables Secure cookies + stricter logs
LOG_LEVEL=debug                                  # debug | info | warn | error (default: info in prod, debug otherwise)

# Database (must match docker-compose.yml or your remote Postgres)
DB_URL=postgres://erp_user:erp_password@localhost:5432/erp_kanban?sslmode=disable

# Migrations (relative to working dir; container uses /app/database/migrations)
MIGRATIONS_PATH=database/migrations
SKIP_MIGRATIONS=false                            # set true if running migrations out-of-band

# JWT — generate with: openssl rand -base64 32
# Keep this STABLE across restarts (a fresh value invalidates every issued
# token, forcing everyone to log in again — a common "logged out on restart"
# cause in dev).
JWT_SECRET=replace-me-with-32+-bytes-of-random

# Session lifetimes (Go duration strings: "15m", "8h", "720h").
# ACCESS_TOKEN_TTL  — access JWT + auth_token cookie lifetime. This is also how
#   long an idle tab survives a plain reload before bouncing to /login (server
#   nav can't see the refresh cookie). Longer = fewer relogins, but a leaked
#   access token (not revocable) is usable for this whole window.
#   Default 8h (a work session). Production may tighten to e.g. 15m–1h.
# REFRESH_TOKEN_TTL — rotating, revocable refresh token. The real "stay logged
#   in" window for active users. Default 720h (30d).
ACCESS_TOKEN_TTL=8h
REFRESH_TOKEN_TTL=720h

# Frontend (used for CORS allow-origin and OAuth post-auth redirect)
FRONTEND_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Sentry (optional). Leave SENTRY_DSN empty to disable observability shipping.
SENTRY_DSN=
SENTRY_ENVIRONMENT=                              # defaults to ENV
SENTRY_RELEASE=                                  # defaults to ldflags-injected version
