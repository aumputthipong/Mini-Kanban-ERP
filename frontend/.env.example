# ─────────────────────────────────────────────────────────────────────────────
# Frontend env vars — copy to .env.local and fill in real values
# Vars prefixed with NEXT_PUBLIC_ are inlined at build time and visible to the
# browser. Anything else stays server-side only.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base — used by every fetch in src/lib/apiClient.ts
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# WebSocket base — used by useWebSocket hook
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
